# ============================================
# AL-WID NEWS PLATFORM - Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/alwid_news
MONGODB_URI_TEST=mongodb://localhost:27017/alwid_news_test

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_RESET_EXPIRES=1h

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_ARTICLES=alwid_articles

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=alwid_articles

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@alwid.com
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=الود - AL-WID
EMAIL_FROM_ADDRESS=noreply@alwid.com

# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@alwid.com

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=100
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_ADMIN_MAX=300

# Sitemap
SITEMAP_BASE_URL=https://alwid.com
SITEMAP_OUTPUT_DIR=./public/sitemaps

# BullMQ
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/alwid.log

# Admin Seed User
SEED_ADMIN_EMAIL=admin@alwid.com
SEED_ADMIN_PASSWORD=Admin@123
